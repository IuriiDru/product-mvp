# Пример переменных окружения. Скопируйте в .env и заполните своими значениями.
# Файл .env в .gitignore — реальные секреты в репозиторий не попадают.

# Строка подключения к базе данных (Prisma)
DATABASE_URL=

# Доступ к админке заявок (/admin), HTTP Basic Auth.
# Задайте свой логин и СИЛЬНЫЙ пароль. Без этих переменных админка закрыта (503).
ADMIN_USER=
ADMIN_PASSWORD=

# Уведомления о заявках через Resend (необязательно для локальной разработки)
RESEND_API_KEY=
LEAD_NOTIFY_TO=kobzeva@univeige.ru
LEAD_NOTIFY_FROM=Юнивеж · Аудит <onboarding@resend.dev>
APP_URL=https://buh.univeige.ru
